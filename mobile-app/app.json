    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "a2b8e302-5545-481a-bd0f-fad7dace6be4"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
